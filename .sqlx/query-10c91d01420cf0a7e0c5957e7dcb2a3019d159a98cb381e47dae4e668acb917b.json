{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n          id, user_id, wallet_pubkey, mint, symbol, decimals, raw_amount,\n          CAST(ui_amount  AS FLOAT8) AS ui_amount,\n          CAST(usd_value  AS FLOAT8) AS usd_value,\n          last_synced_at\n        FROM wallet_balances\n        WHERE user_id = $1\n        ORDER BY usd_value DESC NULLS LAST\n        ",
