{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n          id, user_id, signature,\n          type AS txn_type,\n          status, amount, mint, from_address, to_address, fee,\n          metadata AS \"metadata: Value\",\n          confirmed_at, created_at, updated_at\n        FROM transactions\n        WHERE user_id = $1 AND type = 'swap'\n        ORDER BY created_at DESC\n        LIMIT $2 OFFSET $3\n        ",
