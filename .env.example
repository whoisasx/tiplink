# Use .sqlx/ cache for compile-time query checks — no DB connection needed at build time
SQLX_OFFLINE=true

GOOGLE_OAUTH_CLIENT_ID="your_google_client_id"
GOOGLE_OAUTH_CLIENT_SECRET="your_google_client_secret"

REDIRECT_URL="http://localhost:3000/api/auth/callback/google"
JWT_SECRET="your_jwt_secret"

TOKEN_EXPIRED_IN="60m"
TOKEN_MAXAGE="60"

# Change according to the frontend hosted port
CLIENT_ORIGIN="http://localhost:5173"
BASE_URL="http://localhost:3000"

# Runtime connection — direct (no pooler), works with sqlx prepared statements
DATABASE_URL="postgresql://user:pass@host.region.aws.neon.tech/dbname?sslmode=require"

# Also used for: cargo sqlx prepare / make sqlx-prepare
DIRECT_DATABASE_URL="postgresql://user:pass@host.region.aws.neon.tech/dbname?sslmode=require"

# To prevent CSRF attacks
RANDOM_CSRF_STRING="your_csrf_secret"

SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"

MPC_SERVER_URL="http://localhost:4000"
MPC_MASTER_SECRET="your_mpc_master_secret"

ESCROW_PUBLIC_KEY="your_escrow_solana_pubkey"
ESCROW_PRIVATE_KEY="your_escrow_private_key"
ESCROW_HMAC_SECRET="your_escrow_hmac_secret"

JUPITER_QUOTE_URL="https://quote-api.jup.ag/v6/quote"
JUPITER_SWAP_URL="https://quote-api.jup.ag/v6/swap"
SOL_MINT="So11111111111111111111111111111111111111112"
SOLANA_BASE_FEE_LAMPORTS=5000