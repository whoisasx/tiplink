  "query": "\n    INSERT INTO users(google_sub, email, display_name, avatar_url)\n    VALUES ($1, $2, $3, $4)\n    ON CONFLICT (google_sub)\n    DO UPDATE\n      SET display_name=EXCLUDED.display_name,\n          avatar_url=EXCLUDED.avatar_url,\n          updated_at=NOW()\n    RETURNING *\n    ",
